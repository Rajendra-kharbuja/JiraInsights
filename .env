# Jira API Configuration
# Replace with your actual Jira instance URL, email, and API token/password.

# Base URL of your Jira instance (e.g., https://your-domain.atlassian.net)
JIRA_URL="https://your-domain.atlassian.net"

# Email address associated with your Jira account
JIRA_EMAIL="your-email@example.com"

# Your Jira API token (recommended) or password.
# For Jira Cloud, create an API token here: https://id.atlassian.com/manage-profile/security/api-tokens
# For Jira Server, this might be your password, but using a Personal Access Token (PAT) is often preferred if available.
JIRA_PASSWORD="your_api_token_or_password"

# --- Optional Configuration ---
# LOG_LEVEL: Set the logging level for the application.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# LOG_LEVEL="INFO"

# OUTPUT_FORMAT: Define the format for the generated reports.
# Options: csv, json, excel
# Default: csv
# OUTPUT_FORMAT="csv"

# REPORT_FILENAME: Define the base name for the report files (without extension).
# Default: jira_issues_report
# REPORT_FILENAME="my_custom_jira_report"