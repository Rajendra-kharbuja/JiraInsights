# Example environment variables for Jira Insights
# Copy this file to .env and fill in your actual values.
# DO NOT COMMIT THE ACTUAL .env FILE TO VERSION CONTROL (it's in .gitignore).

# Your full Jira instance URL (e.g., https://your-domain.atlassian.net for Cloud)
JIRA_URL=https://your-domain.atlassian.net

# The email address associated with your Atlassian account
JIRA_EMAIL=your-email@example.com

# Your Jira API token. For Jira Cloud, create one from your Atlassian account security settings.
# Ensure this .env file is protected.
JIRA_API_TOKEN=your_actual_jira_api_token_here
