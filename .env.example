# Jira Instance Connection Details
# ---------------------------------
# Replace with your actual Jira instance URL
JIRA_URL=https://your-domain.atlassian.net

# Your email address associated with your Jira account
JIRA_EMAIL=your-email@example.com

# Your Jira account password.
# IMPORTANT: Using your primary password for Basic Authentication is generally
# less secure than using API tokens. API tokens are the recommended method
# if your Jira instance supports them and your organization's policies allow.
# This project currently uses Basic Auth with Email/Password.
JIRA_PASSWORD=your_actual_password_here

# Other potential configurations (add as needed)
# Example:
# JIRA_PROJECT_KEY=MYPROJ
# DEFAULT_JQL_QUERY="project = MYPROJ AND status = Done"